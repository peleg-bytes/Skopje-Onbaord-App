# Copy to keystore.properties (gitignored) and adjust paths/passwords.
# Generate a keystore once:
#   keytool -genkeypair -v -storetype PKCS12 -keystore release.keystore -alias skopje-onboard -keyalg RSA -keysize 2048 -validity 10000

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=skopje-onboard
storeFile=release.keystore
